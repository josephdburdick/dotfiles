#!/usr/bin/env bash
# claude-md-bootstrap — inject the llm-tools cheap-worker delegation block
# into a target repo's CLAUDE.md, idempotently.
#
# Usage:
#   claude-md-bootstrap [path]          # path defaults to $PWD
#   claude-md-bootstrap --check [path]  # exit 0 if block present, 1 if missing
#   claude-md-bootstrap --force [path]  # replace existing block (default behavior on re-run)
#   claude-md-bootstrap --print          # print the template to stdout, no file write
#
# The block is bracketed by:
#   <!-- llm-tools:v1:begin -->
#   ...
#   <!-- llm-tools:v1:end -->
# Re-running replaces the existing block in place, so updating the template
# upstream and re-running propagates changes.

set -euo pipefail

SCRIPT_NAME="${0##*/}"

# Resolve template path. Prefer the stowed location at ~/.claude/templates/,
# fall back to the dotfiles source if not yet stowed.
TEMPLATE_CANDIDATES=(
  "${HOME}/.claude/templates/llm-tools.CLAUDE.md"
  "${HOME}/.dotfiles/claude/dot-claude/templates/llm-tools.CLAUDE.md"
)
TEMPLATE=""
for candidate in "${TEMPLATE_CANDIDATES[@]}"; do
  if [[ -f "$candidate" ]]; then
    TEMPLATE="$candidate"
    break
  fi
done

if [[ -z "$TEMPLATE" ]]; then
  echo "$SCRIPT_NAME: cannot find llm-tools.CLAUDE.md template in:" >&2
  for candidate in "${TEMPLATE_CANDIDATES[@]}"; do
    echo "  - $candidate" >&2
  done
  exit 2
fi

BEGIN_MARKER='<!-- llm-tools:v1:begin -->'
END_MARKER='<!-- llm-tools:v1:end -->'

mode="apply"
target_dir=""
while (( $# )); do
  case "$1" in
    --check) mode="check"; shift ;;
    --force) mode="apply"; shift ;;  # default; kept for clarity
    --print) mode="print"; shift ;;
    -h|--help)
      sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    --) shift; target_dir="${1:-}"; break ;;
    -*)
      echo "$SCRIPT_NAME: unknown flag: $1" >&2
      exit 2
      ;;
    *)
      target_dir="$1"; shift ;;
  esac
done

if [[ "$mode" == "print" ]]; then
  cat "$TEMPLATE"
  exit 0
fi

target_dir="${target_dir:-$PWD}"
if [[ ! -d "$target_dir" ]]; then
  echo "$SCRIPT_NAME: not a directory: $target_dir" >&2
  exit 2
fi

target_file="$target_dir/CLAUDE.md"

if [[ "$mode" == "check" ]]; then
  if [[ -f "$target_file" ]] && grep -qF "$BEGIN_MARKER" "$target_file"; then
    echo "ok: $target_file already contains llm-tools v1 block"
    exit 0
  fi
  echo "missing: $target_file lacks llm-tools v1 block"
  exit 1
fi

# Apply mode: create or update CLAUDE.md
template_body="$(cat "$TEMPLATE")"

if [[ ! -f "$target_file" ]]; then
  printf '# CLAUDE.md\n\n%s\n' "$template_body" > "$target_file"
  echo "created: $target_file"
  exit 0
fi

if grep -qF "$BEGIN_MARKER" "$target_file"; then
  # Replace the existing block in place. Read the template via getline so we
  # avoid passing multi-line content through awk -v (BSD awk rejects newlines
  # in -v assignments). The template file already contains both markers.
  tmp="$(mktemp)"
  awk -v begin="$BEGIN_MARKER" -v end="$END_MARKER" -v tpl="$TEMPLATE" '
    BEGIN { in_block = 0 }
    {
      if (!in_block && index($0, begin) > 0) {
        while ((getline line < tpl) > 0) print line
        close(tpl)
        in_block = 1
        next
      }
      if (in_block) {
        if (index($0, end) > 0) { in_block = 0 }
        next
      }
      print
    }
  ' "$target_file" > "$tmp"
  mv "$tmp" "$target_file"
  echo "updated: $target_file (replaced llm-tools v1 block)"
  exit 0
fi

# Block missing — append with a leading blank line if file doesn't end in one.
if [[ -n "$(tail -c1 "$target_file" 2>/dev/null)" ]]; then
  printf '\n' >> "$target_file"
fi
printf '\n%s\n' "$template_body" >> "$target_file"
echo "appended: $target_file"
