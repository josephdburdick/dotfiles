# Environment files with sensitive information
.env
.env.local
.env.*.local

# API keys and secrets
*API_KEY*
*SECRET*
*TOKEN*

# SSH keys
id_rsa
id_ed25519
*.pem

# Password files
*.password
*.passwd

# Tmux plugin manager plugins (managed locally by TPM)
tmux/.config/tmux/plugins/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Konsole runtime/plugin/cache data (generated)
konsole/.local/share/*
# Keep tracked Konsole theme
!konsole/.local/share/konsole/
!konsole/.local/share/konsole/nord.colorscheme

# Local tool binaries that are machine-generated
bin/.local/bin/agent
bin/.local/bin/uv
bin/.local/bin/uvx

# Cursor agent
bin/.local/bin/cursor-agent