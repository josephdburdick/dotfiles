# Environment files with sensitive information
.env
.env.local
.env.*.local

# API keys and secrets
*API_KEY*
*SECRET*
*TOKEN*

# SSH keys
id_rsa
id_ed25519
*.pem

# Password files
*.password
*.passwd

# Tmux plugin manager plugins (managed locally by TPM)
tmux/.config/tmux/plugins/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Konsole runtime/plugin/cache data (generated)
konsole/.local/share/*
# Keep tracked Konsole theme
!konsole/.local/share/konsole/
!konsole/.local/share/konsole/nord.colorscheme

# Local tool binaries that are machine-generated (install via brew/package manager)
bin/.local/bin/agent
bin/.local/bin/uv
bin/.local/bin/uvx
bin/.local/bin/goose
bin/.local/bin/temporal
bin/.local/bin/temporal-service
# claude: native-installer symlink to ~/.local/share/claude/versions/<ver> (machine/user-specific; owned by the Claude Code installer, not stow)
bin/.local/bin/claude
# analytics-mcp: pipx-venv symlinks (machine-specific absolute paths; install via pipx)
bin/.local/bin/analytics-mcp
bin/.local/bin/google-analytics-mcp

# Claude Code runtime task/transcript data (machine-generated)
claude/dot-claude/tasks/

# Python bytecode cache
bin/.local/bin/__pycache__/

# Cursor agent
bin/.local/bin/cursor-agent